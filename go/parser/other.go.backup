// parseCommaSeparatedObjectNames parses a comma-separated list of object names
func parseCommaSeparatedObjectNames(p *Parser) ([]*ast.ObjectName, error) {
	var names []*ast.ObjectName
	for {
		name, err := p.ParseObjectName()
		if err != nil {
			return nil, err
		}
		names = append(names, name)
		if !p.ParseKeyword(",") {
			break
		}
	}
	return names, nil
}

// parseCommaSeparatedIdents parses a comma-separated list of identifiers
func parseCommaSeparatedIdents(p *Parser) ([]*ast.Ident, error) {
	var names []*ast.Ident
	for {
		name, err := p.ParseIdentifier()
		if err != nil {
			return nil, err
		}
		names = append(names, name)
		if !p.ParseKeyword(",") {
			break
		}
	}
	return names, nil
}


// ParseDrop parses DROP statements
func ParseDrop(p *Parser) (ast.Statement, error) {
	// Check for DROP ... IF EXISTS
	ifExists := p.ParseKeywords([]string{"IF", "EXISTS"})

	// Try various DROP targets
	targets := []struct {
		kw     string
		parser func() (ast.Statement, error)
	}{
		{"TABLE", func() (ast.Statement, error) { return parseDropTable(p, ifExists) }},
		{"VIEW", func() (ast.Statement, error) { return parseDropView(p, ifExists) }},
		{"INDEX", func() (ast.Statement, error) { return parseDropIndex(p, ifExists) }},
		{"FUNCTION", func() (ast.Statement, error) { return parseDropFunction(p, ifExists) }},
		{"PROCEDURE", func() (ast.Statement, error) { return parseDropProcedure(p, ifExists) }},
		{"ROLE", func() (ast.Statement, error) { return parseDropRole(p, ifExists) }},
		{"DATABASE", func() (ast.Statement, error) { return parseDropDatabase(p, ifExists) }},
		{"SCHEMA", func() (ast.Statement, error) { return parseDropSchema(p, ifExists) }},
		{"SEQUENCE", func() (ast.Statement, error) { return parseDropSequence(p, ifExists) }},
		{"TYPE", func() (ast.Statement, error) { return parseDropType(p, ifExists) }},
		{"DOMAIN", func() (ast.Statement, error) { return parseDropDomain(p, ifExists) }},
		{"EXTENSION", func() (ast.Statement, error) { return parseDropExtension(p, ifExists) }},
		{"TRIGGER", func() (ast.Statement, error) { return parseDropTrigger(p, ifExists) }},
		{"POLICY", func() (ast.Statement, error) { return parseDropPolicy(p, ifExists) }},
		{"CONNECTOR", func() (ast.Statement, error) { return parseDropConnector(p, ifExists) }},
	}

	for _, t := range targets {
		if p.PeekKeyword(t.kw) {
			return t.parser()
		}
	}

	return nil, p.ExpectedRef("TABLE, VIEW, INDEX, FUNCTION, ROLE, DATABASE, SCHEMA, or other DROP target", p.PeekTokenRef())
}

func parseDropTable(p *Parser, ifExists bool) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("TABLE"); err != nil {
		return nil, err
	}

	cascade := p.ParseKeyword("CASCADE")
	restrict := p.ParseKeyword("RESTRICT")
	purge := p.ParseKeyword("PURGE") // Hive

	names, err := parseCommaSeparatedObjectNames(p)
	if err != nil {
		return nil, err
	}

	return &statement.DropTable{
		IfExists: ifExists,
		Names:    names,
		Cascade:  cascade,
		Restrict: restrict,
		Purge:    purge,
	}, nil
}

func parseDropView(p *Parser, ifExists bool) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("VIEW"); err != nil {
		return nil, err
	}

	cascade := p.ParseKeyword("CASCADE")
	restrict := p.ParseKeyword("RESTRICT")

	names, err := parseCommaSeparatedObjectNames(p)
	if err != nil {
		return nil, err
	}

	return &statement.DropView{
		IfExists: ifExists,
		Names:    names,
		Cascade:  cascade,
		Restrict: restrict,
	}, nil
}

func parseDropIndex(p *Parser, ifExists bool) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("INDEX"); err != nil {
		return nil, err
	}

	// Parse index name
	name, err := p.ParseObjectName()
	if err != nil {
		return nil, err
	}

	// Parse optional ON table_name
	var onTable *ast.ObjectName
	if p.ParseKeyword("ON") {
		onTable, err = p.ParseObjectName()
		if err != nil {
			return nil, err
		}
	}

	cascade := p.ParseKeyword("CASCADE")
	restrict := p.ParseKeyword("RESTRICT")

	names := []*ast.ObjectName{name}
	return &statement.DropIndex{
		IfExists: ifExists,
		Names:    names,
		Name:     name,
		OnTable:  onTable,
		Cascade:  cascade,
		Restrict: restrict,
	}, nil
}

func parseDropFunction(p *Parser, ifExists bool) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("FUNCTION"); err != nil {
		return nil, err
	}
	return nil, errors.NewParserError("DROP FUNCTION not fully implemented", span.Span{})
}

