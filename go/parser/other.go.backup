// ParseTruncate parses TRUNCATE TABLE
func ParseTruncate(p *Parser) (ast.Statement, error) {
	// TRUNCATE [ TABLE ] name [, ... ] [ RESTART IDENTITY | CONTINUE IDENTITY ] [ CASCADE | RESTRICT ]
	tableKw := p.ParseKeyword("TABLE")

	names, err := parseCommaSeparatedObjectNames(p)
	if err != nil {
		return nil, err
	}

	var identity *statement.TruncateIdentity
	if p.ParseKeywords([]string{"RESTART", "IDENTITY"}) {
		t := statement.TruncateRestartIdentity
		identity = &t
	} else if p.ParseKeywords([]string{"CONTINUE", "IDENTITY"}) {
		t := statement.TruncateContinueIdentity
		identity = &t
	}

	var cascade *bool
	if p.ParseKeyword("CASCADE") {
		t := true
		cascade = &t
	} else if p.ParseKeyword("RESTRICT") {
		f := false
		cascade = &f
	}

	return &statement.Truncate{
		Table:    tableKw,
		Names:    names,
		Identity: identity,
		Cascade:  cascade,
	}, nil
}

// ParseExplain parses EXPLAIN
func ParseExplain(p *Parser) (ast.Statement, error) {
	// EXPLAIN [ ( option [, ...] ) ] statement
	// EXPLAIN [ ANALYZE ] [ VERBOSE ] statement
	// EXPLAIN QUERY PLAN statement

	var analyze bool
	var verbose bool
	var queryPlan bool
	var estimate bool

	if p.ParseKeywords([]string{"QUERY", "PLAN"}) {
		queryPlan = true
	} else if p.ParseKeyword("ESTIMATE") {
		estimate = true
	} else {
		analyze = p.ParseKeyword("ANALYZE")
		verbose = p.ParseKeyword("VERBOSE")
	}

	// Parse the statement being explained
	stmt, err := p.ParseStatement()
	if err != nil {
		return nil, err
	}

	return &statement.Explain{
		Analyze:   analyze,
		Verbose:   verbose,
		QueryPlan: queryPlan,
		Estimate:  estimate,
		Statement: stmt,
	}, nil
}

// ParseDescribe parses DESCRIBE/DESC
func ParseDescribe(p *Parser) (ast.Statement, error) {
	// DESCRIBE [EXTENDED | FORMATTED] table_name [column_name | partition_spec]
	var extended bool
	var formatted bool

	if p.ParseKeyword("EXTENDED") {
		extended = true
	} else if p.ParseKeyword("FORMATTED") {
		formatted = true
	}

	// Check if table keyword is required
	if p.GetDialect().DescribeRequiresTableKeyword() {
		if _, err := p.ExpectKeyword("TABLE"); err != nil {
			return nil, err
		}
	} else {
		p.ParseKeyword("TABLE") // optional
	}

	tableName, err := p.ParseObjectName()
	if err != nil {
		return nil, err
	}

	return &statement.ExplainTable{
		DescribeAlias:   statement.DescribeAliasDescribe,
		HiveFormat:      extended,
		HasTableKeyword: true,
		TableName:       tableName,
	}, nil
}

// ParseAnalyze parses ANALYZE
func ParseAnalyze(p *Parser) (ast.Statement, error) {
	// ANALYZE [ ( option [, ...] ) ] [ table_name ] [, ...]
	// ANALYZE [ VERBOSE ] [ table_name [ ( column_name [, ...] ) ] ]

	var verbose bool
	var tables []*statement.AnalyzeTable

	if p.ParseKeyword("VERBOSE") {
		verbose = true
	}

	// Parse table names and optional column lists
	for {
		tableName, err := p.ParseObjectName()
		if err != nil {
			break
		}

		var columns []*ast.Ident
		if p.PeekToken() == tokenizer.TokenLParen {
			columns, err = p.ParseParenthesizedColumnList()
			if err != nil {
				return nil, err
			}
		}

		tables = append(tables, &statement.AnalyzeTable{
			TableName: tableName,
			Columns:   columns,
		})

		if !p.ParseToken(tokenizer.TokenComma) {
			break
		}
	}

	return &statement.Analyze{
		Verbose: verbose,
		Tables:  tables,
	}, nil
}

// ParseSet parses SET statements
func ParseSet(p *Parser) (ast.Statement, error) {
	// SET [ SESSION | LOCAL ] configuration_parameter { TO | = } { value | 'value' | DEFAULT }
	// SET [ SESSION | LOCAL ] TIME ZONE { value | 'value' | LOCAL | DEFAULT }
	// SET [ GLOBAL ] variable = expr [, ...] (MySQL)
	// SET ROLE { role_name | NONE }

	var scope statement.SetScope
	if p.ParseKeyword("SESSION") {
		scope = statement.SetScopeSession
	} else if p.ParseKeyword("LOCAL") {
		scope = statement.SetScopeLocal
	} else if p.ParseKeyword("GLOBAL") {
		scope = statement.SetScopeGlobal
	}

	// SET TIME ZONE
	if p.ParseKeyword("TIME") && p.ParseKeyword("ZONE") {
		var value statement.SetTimeZoneValue
		if p.ParseKeyword("LOCAL") {
			value = statement.SetTimeZoneLocal
		} else if p.ParseKeyword("DEFAULT") {
			value = statement.SetTimeZoneDefault
		} else {
			expr, err := p.ParseExpr()
			if err != nil {
				return nil, err
			}
			value = statement.SetTimeZoneExpr{Expr: expr}
		}
		return &statement.SetTimeZone{
			Scope: scope,
			Value: value,
		}, nil
	}

	// SET ROLE
	if p.ParseKeyword("ROLE") {
		var roleName *ast.Ident
		if !p.ParseKeyword("NONE") {
			name, err := p.ParseIdentifier()
			if err != nil {
				return nil, err
			}
			roleName = name
		}
		return &statement.SetRole{
			Scope:    scope,
			RoleName: roleName,
		}, nil
	}

	// SET variable = value
	assignments, err := p.ParseCommaSeparated(parseSetAssignment)
	if err != nil {
		return nil, err
	}

	return &statement.SetVariable{
		Scope:       scope,
		Assignments: assignments,
	}, nil
}

func parseSetAssignment(p *Parser) (*statement.SetAssignment, error) {
	var variable ast.ObjectName
	var isLocal bool

	// Support for @variable (MySQL/MS SQL Server style)
	if p.PeekToken() == tokenizer.TokenAtSign {
		p.NextToken()
		isLocal = true
		name, err := p.ParseIdentifier()
		if err != nil {
			return nil, err
		}
		variable = ast.ObjectName{Parts: []*ast.Ident{name}}
	} else {
		// Standard variable name
		name, err := p.ParseObjectName()
		if err != nil {
			return nil, err
		}
		variable = *name
	}

	// Parse = or TO
	if !p.ParseToken(tokenizer.TokenEq) && !p.ParseKeyword("TO") {
		return nil, p.ExpectedRef("= or TO", p.PeekTokenRef())
	}

	var value expr.Expr
	if p.ParseKeyword("DEFAULT") {
		value = nil
	} else {
		var err error
		value, err = p.ParseExpr()
		if err != nil {
			return nil, err
		}
	}

	return &statement.SetAssignment{
		Variable: variable,
		Value:    value,
		IsLocal:  isLocal,
	}, nil
}

// ParseShow parses SHOW statements
func ParseShow(p *Parser) (ast.Statement, error) {
	// SHOW VARIABLES [LIKE 'pattern']
	// SHOW CREATE TABLE table_name
	// SHOW TABLES [FROM schema] [LIKE 'pattern']
	// SHOW COLUMNS FROM table_name
	// etc.

	// SHOW CREATE ...
	if p.PeekKeyword("CREATE") {
		return parseShowCreate(p)
	}

	// SHOW VARIABLES
	if p.PeekKeyword("VARIABLES") {
		return parseShowVariables(p)
	}

	// SHOW TABLES
	if p.PeekKeyword("TABLES") {
		return parseShowTables(p)
	}

	// SHOW COLUMNS/FIELDS
	if p.PeekKeyword("COLUMNS") || p.PeekKeyword("FIELDS") {
		return parseShowColumns(p)
	}

	// SHOW DATABASES/SCHEMAS
	if p.PeekKeyword("DATABASES") || p.PeekKeyword("SCHEMAS") {
		return parseShowDatabases(p)
	}

	// SHOW INDEX/INDEXES/KEYS
	if p.PeekKeyword("INDEX") || p.PeekKeyword("INDEXES") || p.PeekKeyword("KEYS") {
		return parseShowIndex(p)
	}

	// SHOW GRANTS
	if p.PeekKeyword("GRANTS") {
		return parseShowGrants(p)
	}

	// SHOW COLLATION
	if p.PeekKeyword("COLLATION") {
		return parseShowCollation(p)
	}

	// Generic SHOW
	return parseShowGeneric(p)
}

func parseShowCreate(p *Parser) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("CREATE"); err != nil {
		return nil, err
	}

	var objectType statement.ShowObjectType
	switch {
	case p.ParseKeyword("TABLE"):
		objectType = statement.ShowObjectTable
	case p.ParseKeyword("VIEW"):
		objectType = statement.ShowObjectView
	case p.ParseKeyword("DATABASE"):
		objectType = statement.ShowObjectDatabase
	case p.ParseKeyword("SCHEMA"):
		objectType = statement.ShowObjectSchema
	case p.ParseKeyword("FUNCTION"):
		objectType = statement.ShowObjectFunction
	case p.ParseKeyword("PROCEDURE"):
		objectType = statement.ShowObjectProcedure
	case p.ParseKeyword("TRIGGER"):
		objectType = statement.ShowObjectTrigger
	case p.ParseKeyword("INDEX"):
		objectType = statement.ShowObjectIndex
	case p.ParseKeywords([]string{"MATERIALIZED", "VIEW"}):
		objectType = statement.ShowObjectMaterializedView
	}

	name, err := p.ParseObjectName()
	if err != nil {
		return nil, err
	}

	return &statement.ShowCreate{
		ObjectType: objectType,
		ObjectName: name,
	}, nil
}

func parseShowVariables(p *Parser) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("VARIABLES"); err != nil {
		return nil, err
	}

	var like *string
	var where expr.Expr

	if p.ParseKeyword("LIKE") {
		pattern, err := p.ParseLiteralString()
		if err != nil {
			return nil, err
		}
		like = &pattern
	} else if p.ParseKeyword("WHERE") {
		var err error
		where, err = p.ParseExpr()
		if err != nil {
			return nil, err
		}
	}

	return &statement.ShowVariables{
		Like:  like,
		Where: where,
	}, nil
}

func parseShowTables(p *Parser) (ast.Statement, error) {
	if _, err := p.ExpectKeyword("TABLES"); err != nil {
		return nil, err
	}

	var schema *ast.ObjectName
	var like *string
	var where expr.Expr

	if p.ParseKeyword("FROM") || p.ParseKeyword("IN") {
		var err error
		schema, err = p.ParseObjectName()
		if err != nil {
			return nil, err
		}
	}

	if p.ParseKeyword("LIKE") {
		pattern, err := p.ParseLiteralString()
		if err != nil {
			return nil, err
		}
		like = &pattern
	} else if p.ParseKeyword("WHERE") {
		var err error
		where, err = p.ParseExpr()
		if err != nil {
			return nil, err
		}
	}

	return &statement.ShowTables{
		Schema: schema,
		Like:   like,
		Where:  where,
	}, nil
}

func parseShowColumns(p *Parser) (ast.Statement, error) {
	p.ParseKeyword("COLUMNS") || p.ParseKeyword("FIELDS")

	var tableName *ast.ObjectName
	var schema *ast.ObjectName

	if p.ParseKeyword("FROM") || p.ParseKeyword("IN") {
		var err error
		tableName, err = p.ParseObjectName()
		if err != nil {
			return nil, err
		}
	}

	if p.ParseKeyword("FROM") || p.ParseKeyword("IN") {
		var err error
		schema, err = p.ParseObjectName()
		if err != nil {
			return nil, err
		}
	}

	var like *string
	if p.ParseKeyword("LIKE") {
		pattern, err := p.ParseLiteralString()
		if err != nil {
			return nil, err
		}
		like = &pattern
	}

	return &statement.ShowColumns{
		TableName: tableName,
		Schema:    schema,
		Like:      like,
	}, nil
}

func parseShowDatabases(p *Parser) (ast.Statement, error) {
	p.ParseKeyword("DATABASES") || p.ParseKeyword("SCHEMAS")

	var like *string
	if p.ParseKeyword("LIKE") {
		pattern, err := p.ParseLiteralString()
		if err != nil {
			return nil, err
		}
		like = &pattern
	}

	return &statement.ShowDatabases{
		Like: like,
	}, nil
}

func parseShowIndex(p *Parser) (ast.Statement, error) {
	p.ParseKeyword("INDEX") || p.ParseKeyword("INDEXES") || p.ParseKeyword("KEYS")
	return nil, errors.NewParserError("SHOW INDEX not fully implemented", span.Span{})
}

