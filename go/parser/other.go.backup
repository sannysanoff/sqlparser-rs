func parseShowGeneric(p *Parser) (ast.Statement, error) {
	// Generic SHOW command
	name, err := p.ParseIdentifier()
	if err != nil {
		return nil, err
	}

	return &statement.ShowGeneric{
		Name: name,
	}, nil
}

// ParseGrant parses GRANT
func ParseGrant(p *Parser) (ast.Statement, error) {
	// GRANT privileges ON object_type object_name TO grantees [WITH GRANT OPTION]
	privileges, objects, err := parseGrantDenyRevokePrivilegesObjects(p)
	if err != nil {
		return nil, err
	}

	if _, err := p.ExpectKeyword("TO"); err != nil {
		return nil, err
	}

	grantees, err := parseGrantees(p)
	if err != nil {
		return nil, err
	}

	withGrantOption := p.ParseKeywords([]string{"WITH", "GRANT", "OPTION"})
	grantedBy := p.ParseKeywords([]string{"GRANTED", "BY"})
	var grantedByName *ast.Ident
	if grantedBy {
		name, err := p.ParseIdentifier()
		if err != nil {
			return nil, err
		}
		grantedByName = name
	}

	return &statement.Grant{
		Privileges:      privileges,
		Objects:         objects,
		Grantees:        grantees,
		WithGrantOption: withGrantOption,
		GrantedBy:       grantedByName,
	}, nil
}

// ParseRevoke parses REVOKE
func ParseRevoke(p *Parser) (ast.Statement, error) {
	// REVOKE [GRANT OPTION FOR] privileges ON object_type object_name FROM grantees [CASCADE | RESTRICT]
	grantOptionFor := p.ParseKeywords([]string{"GRANT", "OPTION", "FOR"})

	privileges, objects, err := parseGrantDenyRevokePrivilegesObjects(p)
	if err != nil {
		return nil, err
	}

	if _, err := p.ExpectKeyword("FROM"); err != nil {
		return nil, err
	}

	grantees, err := parseGrantees(p)
	if err != nil {
		return nil, err
	}

	var cascade *bool
	if p.ParseKeyword("CASCADE") {
		t := true
		cascade = &t
	} else if p.ParseKeyword("RESTRICT") {
		f := false
		cascade = &f
	}

	return &statement.Revoke{
		GrantOptionFor: grantOptionFor,
		Privileges:     privileges,
		Objects:        objects,
		Grantees:       grantees,
		Cascade:        cascade,
	}, nil
}

func parseGrantDenyRevokePrivilegesObjects(p *Parser) ([]expr.Privilege, []ast.ObjectName, error) {
	// Parse privileges
	var privileges []expr.Privilege

	if p.ParseKeyword("ALL") {
		p.ParseKeyword("PRIVILEGES") // optional
		privileges = append(privileges, expr.Privilege{Kind: expr.PrivilegeAll})
	} else {
		for {
			priv := parsePrivilege(p)
			if priv == nil {
				break
			}
			privileges = append(privileges, *priv)
			if !p.ParseToken(tokenizer.TokenComma) {
				break
			}
		}
	}

	if _, err := p.ExpectKeyword("ON"); err != nil {
		return nil, nil, err
	}

	// Parse object type and name
	var objects []ast.ObjectName

	if p.ParseKeyword("TABLE") || p.ParseKeyword("TABLES") {
		names, err := p.ParseCommaSeparated(func(p *Parser) (*ast.ObjectName, error) {
			return p.ParseObjectName()
		})
		if err != nil {
			return nil, nil, err
		}
		for _, name := range names {
			objects = append(objects, ast.ObjectName{
				Type: statement.ObjectTypeTable,
				Name: name,
			})
		}
	} else if p.ParseKeyword("SEQUENCE") || p.ParseKeyword("SEQUENCES") {
		names, err := p.ParseCommaSeparated(func(p *Parser) (*ast.ObjectName, error) {
			return p.ParseObjectName()
		})
		if err != nil {
			return nil, nil, err
		}
		for _, name := range names {
			objects = append(objects, ast.ObjectName{
				Type: statement.ObjectTypeSequence,
				Name: name,
			})
		}
	} else if p.ParseKeyword("DATABASE") || p.ParseKeyword("SCHEMA") {
		name, err := p.ParseObjectName()
		if err != nil {
			return nil, nil, err
		}
		objects = append(objects, ast.ObjectName{
			Type: statement.ObjectTypeDatabase,
			Name: name,
		})
	} else {
		// Default to table
		names, err := p.ParseCommaSeparated(func(p *Parser) (*ast.ObjectName, error) {
			return p.ParseObjectName()
		})
		if err != nil {
			return nil, nil, err
		}
		for _, name := range names {
			objects = append(objects, ast.ObjectName{
				Type: statement.ObjectTypeTable,
				Name: name,
			})
		}
	}

	return privileges, objects, nil
}

func parsePrivilege(p *Parser) *expr.Privilege {
	// Parse specific privilege keywords
	privMap := map[string]expr.PrivilegeKind{
		"SELECT":     expr.PrivilegeSelect,
		"INSERT":     expr.PrivilegeInsert,
		"UPDATE":     expr.PrivilegeUpdate,
		"DELETE":     expr.PrivilegeDelete,
		"TRUNCATE":   expr.PrivilegeTruncate,
		"REFERENCES": expr.PrivilegeReferences,
		"TRIGGER":    expr.PrivilegeTrigger,
		"CREATE":     expr.PrivilegeCreate,
		"CONNECT":    expr.PrivilegeConnect,
		"TEMPORARY":  expr.PrivilegeTemporary,
		"EXECUTE":    expr.PrivilegeExecute,
		"USAGE":      expr.PrivilegeUsage,
	}

	for kw, kind := range privMap {
		if p.ParseKeyword(kw) {
			return &expr.Privilege{Kind: kind}
		}
	}

	return nil
}

func parseGrantees(p *Parser) ([]statement.Grantee, error) {
	// Parse comma-separated grantees
	var grantees []statement.Grantee

	for {
		var grantee statement.Grantee

		if p.ParseKeyword("PUBLIC") {
			grantee.Kind = statement.GranteePublic
		} else if p.ParseKeyword("CURRENT_USER") {
			grantee.Kind = statement.GranteeCurrentUser
		} else if p.ParseKeyword("CURRENT_ROLE") {
			grantee.Kind = statement.GranteeCurrentRole
		} else if p.ParseKeyword("SESSION_USER") {
			grantee.Kind = statement.GranteeSessionUser
		} else {
			name, err := p.ParseIdentifier()
			if err != nil {
				return nil, err
			}
			grantee.Kind = statement.GranteeName
			grantee.Name = name
		}

		grantees = append(grantees, grantee)

		if !p.ParseToken(tokenizer.TokenComma) {
			break
		}
	}

	return grantees, nil
}

// ParseDeclare parses DECLARE (cursor)
func ParseDeclare(p *Parser) (ast.Statement, error) {
	// DECLARE cursor_name [ BINARY ] [ ASENSITIVE | INSENSITIVE ] [ [ NO ] SCROLL ] CURSOR [ { WITH | WITHOUT } HOLD ] FOR query
	name, err := p.ParseIdentifier()
	if err != nil {
		return nil, err
	}

	binary := p.ParseKeyword("BINARY")

	var asensitive *bool
	if p.ParseKeyword("ASENSITIVE") {
		f := false
		asensitive = &f
	} else if p.ParseKeyword("INSENSITIVE") {
		t := true
		asensitive = &t
	}

	var scroll *bool
	if p.ParseKeywords([]string{"NO", "SCROLL"}) {
		f := false
		scroll = &f
	} else if p.ParseKeyword("SCROLL") {
		t := true
		scroll = &t
	}

	if _, err := p.ExpectKeyword("CURSOR"); err != nil {
		return nil, err
	}

	var hold *bool
	if p.ParseKeyword("WITH") && p.ParseKeyword("HOLD") {
		t := true
		hold = &t
	} else if p.ParseKeywords([]string{"WITHOUT", "HOLD"}) {
		f := false
		hold = &f
	}

	if _, err := p.ExpectKeyword("FOR"); err != nil {
		return nil, err
	}

	query, err := parseQuery(p)
	if err != nil {
		return nil, err
	}

	return &statement.Declare{
		Name:       name,
		Binary:     binary,
		Asensitive: asensitive,
		Scroll:     scroll,
		Hold:       hold,
		Query:      query.(*statement.Query).Query,
	}, nil
}

// ParseFetch parses FETCH
func ParseFetch(p *Parser) (ast.Statement, error) {
	// FETCH [ direction { FROM | IN } ] cursor_name
	var direction statement.FetchDirection

	if p.ParseKeyword("NEXT") {
		direction = statement.FetchDirectionNext
	} else if p.ParseKeyword("PRIOR") {
		direction = statement.FetchDirectionPrior
	} else if p.ParseKeyword("FIRST") {
		direction = statement.FetchDirectionFirst
	} else if p.ParseKeyword("LAST") {
		direction = statement.FetchDirectionLast
	} else if p.ParseKeyword("ABSOLUTE") {
		count, err := p.ParseExpr()
		if err != nil {
			return nil, err
		}
		direction = statement.FetchDirectionAbsolute{Count: count}
	} else if p.ParseKeyword("RELATIVE") {
		count, err := p.ParseExpr()
		if err != nil {
			return nil, err
		}
		direction = statement.FetchDirectionRelative{Count: count}
	} else if p.ParseKeyword("FORWARD") {
		if p.ParseKeyword("ALL") {
			direction = statement.FetchDirectionForwardAll
		} else {
			count, err := p.ParseExpr()
			if err != nil {
				return nil, err
			}
			direction = statement.FetchDirectionForward{Count: count}
		}
	} else if p.ParseKeyword("BACKWARD") {
		if p.ParseKeyword("ALL") {
			direction = statement.FetchDirectionBackwardAll
		} else {
			count, err := p.ParseExpr()
			if err != nil {
				return nil, err
			}
			direction = statement.FetchDirectionBackward{Count: count}
		}
	} else {
		direction = statement.FetchDirectionNext
	}

	p.ParseKeyword("FROM") || p.ParseKeyword("IN")

	name, err := p.ParseIdentifier()
	if err != nil {
		return nil, err
	}

	return &statement.Fetch{
		Direction:  direction,
		CursorName: name,
	}, nil
}

// ParseClose parses CLOSE
func ParseClose(p *Parser) (ast.Statement, error) {
	// CLOSE cursor_name | CLOSE ALL
	if p.ParseKeyword("ALL") {
		return &statement.Close{All: true}, nil
	}

	name, err := p.ParseIdentifier()
	if err != nil {
		return nil, err
	}

	return &statement.Close{
		CursorName: name,
	}, nil
}

// ParseCopy parses COPY (PostgreSQL)
func ParseCopy(p *Parser) (ast.Statement, error) {
	// COPY table_name [ ( column_name [, ...] ) ]
	//     FROM { 'filename' | STDIN } [ [ WITH ] ( option [, ...] ) ]
	//     [ WHERE condition ]
	// OR
	// COPY { table_name [ ( column_name [, ...] ) ] | ( query ) }
	//     TO { 'filename' | STDOUT } [ [ WITH ] ( option [, ...] ) ]

	tableName, err := p.ParseObjectName()
	if err != nil {
		return nil, err
	}

	var columns []*ast.Ident
	if p.PeekToken() == tokenizer.TokenLParen {
		columns, err = p.ParseParenthesizedColumnList()
		if err != nil {
			return nil, err
		}
	}

	var direction statement.CopyDirection
	var source statement.CopySource
	var target statement.CopyTarget

	if p.ParseKeyword("FROM") {
		direction = statement.CopyDirectionFrom
		if p.ParseKeyword("STDIN") {
			source = statement.CopySourceStdin{}
		} else {
			filename, err := p.ParseLiteralString()
			if err != nil {
				return nil, err
			}
			source = statement.CopySourceFile{Filename: filename}
		}
	} else if p.ParseKeyword("TO") {
		direction = statement.CopyDirectionTo
		if p.ParseKeyword("STDOUT") {
			target = statement.CopyTargetStdout{}
		} else {
			filename, err := p.ParseLiteralString()
			if err != nil {
				return nil, err
			}
			target = statement.CopyTargetFile{Filename: filename}
		}
	} else {
		return nil, p.ExpectedRef("FROM or TO", p.PeekTokenRef())
	}

	// Parse options
	var options []statement.CopyOption
	if p.ParseKeyword("WITH") || p.PeekToken() == tokenizer.TokenLParen {
		if p.PeekToken() == tokenizer.TokenLParen {
			options, err = p.ParseCommaSeparated(parseCopyOption)
			if err != nil {
				return nil, err
			}
		}
	}

	var where expr.Expr
	if p.ParseKeyword("WHERE") {
		where, err = p.ParseExpr()
		if err != nil {
			return nil, err
		}
	}

	return &statement.Copy{
		TableName: tableName,
		Columns:   columns,
		Direction: direction,
		Source:    source,
		Target:    target,
		Options:   options,
		Where:     where,
	}, nil
}

func parseCopyOption(p *Parser) (statement.CopyOption, error) {
	name, err := p.ParseIdentifier()
	if err != nil {
		return statement.CopyOption{}, err
	}

	var value expr.Expr
	if p.ParseToken(tokenizer.TokenEq) {
		value, err = p.ParseExpr()
		if err != nil {
			return statement.CopyOption{}, err
		}
	}

	return statement.CopyOption{
		Name:  name,
		Value: value,
	}, nil
}

// ParseUse parses USE (MySQL/SQL Server)
func ParseUse(p *Parser) (ast.Statement, error) {
	name, err := p.ParseIdentifier()
	if err != nil {
		return nil, err
	}

	return &statement.Use{
		Database: name,
	}, nil
}

// ParseCall parses CALL (stored procedure)
func ParseCall(p *Parser) (ast.Statement, error) {
	name, err := p.ParseObjectName()
	if err != nil {
		return nil, err
	}

	var args []expr.Expr
	if p.PeekToken() == tokenizer.TokenLParen {
		if err := p.ExpectToken(tokenizer.TokenLParen); err != nil {
			return nil, err
		}
		if !p.PeekToken() == tokenizer.TokenRParen {
			args, err = p.ParseCommaSeparated(func(p *Parser) (expr.Expr, error) {
				return p.ParseExpr()
			})
			if err != nil {
				return nil, err
			}
		}
		if err := p.ExpectToken(tokenizer.TokenRParen); err != nil {
			return nil, err
		}
	}

	return &statement.Call{
		FunctionName: name,
		Args:         args,
	}, nil
}

